@model WorkShop.ViewModel.ReviewPartsRequestsViewModel

<div class="container mt-5">
    <!-- Header & Search -->
    <div class="row mb-4 align-items-center">
        <div class="col-md-6">
            <h3 class="text-primary"><i class="bi bi-clipboard-check"></i> Requests Awaiting Engineer Approval</h3>
        </div>
        <div class="col-md-6">
            <form class="d-flex" method="get">
                <input class="form-control me-2 shadow-sm" type="search" name="searchTerm" placeholder="Search by Serial / Technician / Device" value="@Model.SearchTerm">
                <button class="btn btn-outline-primary" type="submit">Search</button>
            </form>
        </div>
    </div>

    <hr class="mb-4" />

    <!-- Table -->
    <div class="table-responsive rounded shadow-sm">
        <table class="table  table-hover align-middle mb-0">
            <thead class="table-dark text-center">
                <tr>
                    <th>Device</th>
                    <th>Serial Number</th>
                    <th>Technician</th>
                    <th>Technician Report</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var device in Model.devices)
                {
                    <tr data-url="@Url.Action("DetailsPartsRequests", "Engineer", new { id = device.Id })" style="cursor:pointer;">
                        <td>@device.Product?.Name</td>
                        <td>@device.SerialNumber</td>
                        <td>@device.Technician?.FullName</td>
                        <td>@device.MaintenanceCard?.TechnicianReport</td>
                        <td class="text-center">
                            <div class="d-flex justify-content-center gap-2">
                                <form method="post" asp-action="ApproveParts" asp-controller="Engineer" asp-route-id="@device.Id">
                                    <button type="submit" class="btn btn-success btn-sm">
                                        <i class="bi bi-check-circle"></i> Approve
                                    </button>
                                </form>
                                <form method="post" asp-action="RejectParts" asp-controller="Engineer" asp-route-id="@device.Id">
                                    <button type="submit" class="btn btn-danger btn-sm">
                                        <i class="bi bi-x-circle"></i> Reject
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { page = i, searchTerm = Model.SearchTerm })">@i</a>
                </li>
            }
        </ul>
    </nav>
</div>

<!-- Modal: General Message -->
<div class="modal fade" id="messageModal" tabindex="-1" aria-labelledby="messageModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow-sm">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title" id="messageModalLabel">ℹ️ Message</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center">
                <p id="modalMessage" class="fs-6 text-dark"></p>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="messageSuccess" tabindex="-1" aria-labelledby="messageModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title" id="messageModalLabel">Notification</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center">
                <p id="modalMessageSuccess" class="fs-6 mb-0"></p>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script>



        // Show error modal if error exists
          document.addEventListener("DOMContentLoaded", function () {
              const success = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["Success"]));
              const error = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["Error"]));

              if (error && error.trim() !== "") {
                  document.getElementById("modalMessage").textContent = error;
                  const modal = new bootstrap.Modal(document.getElementById("messageModal"));
                  modal.show();
              }

              if (success && success.trim() !== "") {
                  document.getElementById("modalMessageSuccess").textContent = success;
                  const modal = new bootstrap.Modal(document.getElementById("messageSuccess"));
                  modal.show();
              }
          });


    </script>
    <style>
        body {
            background-color: #f8f9fa;
        }

        .table td, .table th {
            vertical-align: middle;
        }
    </style>
    <script>
        // Navigate on row click
        document.querySelectorAll("tr[data-url]").forEach(row => {
            row.addEventListener("click", function () {
                window.location.href = this.dataset.url;
            });
        });
    </script>

}


