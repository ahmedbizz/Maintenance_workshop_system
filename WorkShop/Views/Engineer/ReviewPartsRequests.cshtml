@model WorkShop.ViewModel.ReviewPartsRequestsViewModel

<div class="container mt-4">
    <h2 class="text-primary">طلبات قطع الغيار</h2>
    <div class="col-6 text-center align-items-center">

        <form class="d-flex">
            <input class="form-control me-sm-2" type="search" name="searchTerm" placeholder="Search" value="@Model.SearchTerm">
            <button class="btn btn-secondary my-2 my-sm-0" type="submit">Search</button>
        </form>
    </div>
    <hr />
    <table class="table table-bordered  table-hover">
        <thead class="table-dark">
            <tr>
                <th>اسم الجهاز</th>
                <th>الرقم التسلسلي</th>
                <th>اسم الفني</th>
                <th>التقرير الفني</th>
                <th>إجراءات</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var device in Model.devices)
            {
                <tr data-url="@Url.Action("DetailsPartsRequests", "Engineer", new { id = device.Id })" style="cursor:pointer;">
                    <td>@device.Product?.Name</td>
                    <td>@device.SerialNumber</td>
                    <td>@device.Technician?.FullName</td>
                    <td>@device.MaintenanceCard?.TechnicianReport</td>
                    <td>
                        <form method="post" asp-action="ApproveParts" asp-controller="Engineer" asp-route-id="@device.Id" style="display:inline-block">
                            <button class="btn btn-success btn-sm">موافقة</button>
                        </form>
                        <form method="post" asp-action="RejectParts" asp-controller="Engineer" asp-route-id="@device.Id" style="display:inline-block">
                            <button class="btn btn-danger btn-sm">رفض</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <nav>
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { page = i })">@i</a>
                </li>
            }
        </ul>
    </nav>
</div>

@section Scripts {
    <script>
        document.querySelectorAll("tr[data-url]").forEach(
        row => { row.addEventListener("click",()=>{
            window.location.href = row.dataset.url;
        });
        
        });

    </script>
                        }