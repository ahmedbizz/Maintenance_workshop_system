@model Product
@{
    ViewData["Title"] = "Create Product";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-primary text-white text-center rounded-top-4">
                    <h3 class="mb-0"><i class="bi bi-box-seam"></i> Create product</h3>
                </div>

                <form method="post" asp-controller="Product" asp-action="Create" enctype="multipart/form-data">
                    <div class="card-body px-4 py-4">

                        <!-- صورة المنتج -->
                        <div class="text-center mb-4">
                            <input id="imageInput" type="file" asp-for="clientFile" hidden onchange="loadFile(event)" />
                            <img id="proImg"
                                 src="@(Model?.imagePath != null ? Url.Content("~/images/" + Model.imagePath) : Url.Content("~/images/user.png"))"
                                 class="img-thumbnail shadow-sm"
                                 style="height: 150px; width: 150px; object-fit: cover; cursor: pointer; border-radius: 50%;"
                                 onclick="document.getElementById('imageInput').click();" />
                            <div class="form-text mt-2">Click image to upload</div>
                        </div>

                        <!-- اسم المنتج -->
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold">Product Name</label>
                            <input asp-for="Name" class="form-control" placeholder="Enter product name" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <!-- رقم القطعة -->
                        <div class="mb-3">
                            <label asp-for="PartNumber" class="form-label fw-bold">Part Number</label>
                            <input asp-for="PartNumber" class="form-control" placeholder="Enter part number" />
                            <span asp-validation-for="PartNumber" class="text-danger small"></span>
                        </div>

                        <!-- وصف المنتج -->
                        <div class="mb-3">
                            <label asp-for="Desc" class="form-label fw-bold">Description</label>
                            <textarea asp-for="Desc" class="form-control" rows="3" placeholder="Enter description"></textarea>
                            <span asp-validation-for="Desc" class="text-danger small"></span>
                        </div>

                        <!-- القسم -->
                        <div class="mb-3">
                            <label asp-for="DepartmentId" class="form-label fw-bold">Department</label>
                            <select asp-for="DepartmentId" class="form-select" asp-items="ViewBag.Departments">
                                <option value="">-- Select Department --</option>
                            </select>
                            <span asp-validation-for="DepartmentId" class="text-danger small"></span>
                        </div>

                        <!-- الأزرار -->
                        <div class="text-center mt-4">
                            <button type="submit" class="btn btn-success px-4 me-2"><i class="bi bi-floppy"></i> Save</button>
                            <a asp-action="Index" asp-controller="Product" class="btn btn-outline-primary px-4"><i class="bi bi-arrow-left"></i> Back</a>
                        </div>

                        <!-- ملخص الأخطاء -->
                        <div class="mt-3">
                            <div asp-validation-summary="All" class="text-danger small"></div>
                        </div>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const loadFile = (event) => {
            const reader = new FileReader();
            reader.onload = () => {
                const proImg = document.getElementById('proImg');
                proImg.src = reader.result;
            }
            reader.readAsDataURL(event.target.files[0]);
        }
    </script>
}
