@model IEnumerable<Product>
@{
    ViewData["Title"] = "Product";
}

<div class="row pt-4 align-items-center">

    <div class="col-6">
        <h1 class="text-primary">Products</h1>
    </div>
    <div class="col-6 text-end align-items-center">
        <a asp-action="Create" asp-controller="Product" class="btn btn-primary"><i class="bi bi-plus-lg"></i>Create</a>

    </div>

    <table class="table tab-content shadow m-4 p-2 table-hover">
        <thead>
        <th>ID</th>
        <th>Img</th>
        <th>Name</th>
        <th>Department</th>
        <th>Create At</th>
        <th>Update At</th>
        <th></th>
        </thead>
        <tbody>
            @foreach (var product in Model)
            {
                <tr style="cursor:pointer" onclick="location.href='@Url.Action("Details", "Product", new { id = @product.Id })'">
                    <td width="10%">@product.Id</td>
                    <td width="10%"><img src="~/images/@product.imagePath" style="width:50px;height:50px" class="shadow" /></td>
                    <td width="20%">@product.Name</td>
                    <td width="10%">@product.department.Name</td>
                    <td width="20%">@product.CreateAt</td>
                    <td width="20%">@product.UpdateAt</td>
                    <td width="15%">
                        <a asp-controller="Product" asp-action="Create" asp-route-Id="@product.Id"><i class=" bi-pencil-square text-primary"></i></a>

                        &nbsp;
                        <form asp-action="Delete" method="post" style="display:inline;">
                            <input type="hidden" name="Id" value="@product.Id" />
                            <button type="submit" class="btn btn-link p-0 m-0 border-0 text-danger" onclick="return confirm('Are you sure you want to delete this item?');">
                                <i class="bi-trash3"></i>
                            </button>
                        </form>
                    </td>

                </tr>
            }
        </tbody>

    </table>



</div>

