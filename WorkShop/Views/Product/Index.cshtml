@model WorkShop.ViewModel.ProductListViewModel
@{
    ViewData["Title"] = "Products";
}
@using System.Text.Json

<div class="container mt-4">
    <div class="card shadow rounded-4">
        <div class="card-body">
            <div class="row mb-3 align-items-center">
                <div class="col-md-4">
                    <h3 class="text-primary"><i class="bi bi-box-seam"></i> Product Management</h3>
                </div>
                <div class="col-md-4">
                    <form class="d-flex" method="get">
                        <input class="form-control me-2" type="search" name="searchTerm" placeholder="Search by name or part number" value="@Model.SearchTerm">
                        <button class="btn btn-outline-primary" type="submit"><i class="bi bi-search"></i></button>
                    </form>
                </div>
                <div class="col-md-4 text-end">
                    <button type="button" class="btn btn-outline-secondary me-2 btnImportExcel" data-bs-toggle="modal" data-bs-target="#ImportExcel">
                        <i class="bi bi-upload"></i> Import Excel
                    </button>
                    <a asp-action="Create" class="btn btn-primary">
                        <i class="bi bi-plus-circle me-1"></i> Create Product
                    </a>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-hover shadow-sm align-middle text-center">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Image</th>
                            <th>Name</th>
                            <th>Department</th>
                            <th>Created</th>
                            <th>Updated</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var product in Model.Products)
                        {
                            <tr class="text-center">
                                <td>@product.Id</td>
                                <td><img src="~/images/@product.imagePath" class="rounded shadow-sm" style="width:50px; height:50px;" /></td>
                                <td>@product.Name</td>
                                <td>@product.department.Name</td>
                                <td>@product.CreateAt.ToShortDateString()</td>
                                <td>@product.UpdateAt.ToShortDateString()</td>
                                <td>
                                    <a asp-action="Create" asp-route-Id="@product.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <button type="button" class="btn btn-sm btn-outline-danger btnDelete" data-id="@product.Id">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            @{
                int maxPagesToShow = 5;
                int startPage = Math.Max(1, Model.CurrentPage - maxPagesToShow / 2);
                int endPage = Math.Min(Model.TotalPages, startPage + maxPagesToShow - 1);
                if (endPage - startPage < maxPagesToShow - 1)
                {
                    startPage = Math.Max(1, endPage - maxPagesToShow + 1);
                }
            }

            <nav>
                <ul class="pagination justify-content-center">
                    <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link" href="@Url.Action("Index", new { page = Model.CurrentPage - 1 })">&laquo;</a>
                    </li>

                    @for (int i = startPage; i <= endPage; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                            <a class="page-link" href="@Url.Action("Index", new { page = i })">@i</a>
                        </li>
                    }

                    <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                        <a class="page-link" href="@Url.Action("Index", new { page = Model.CurrentPage + 1 })">&raquo;</a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</div>
<!-- Modal: Import Excel -->
<div class="modal fade" id="ImportExcel" tabindex="-1" aria-labelledby="importExcelLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow-lg border-0">
            <form asp-action="ImportExcel" asp-controller="Report" method="post" enctype="multipart/form-data">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title" id="importExcelLabel"><i class="bi bi-file-earmark-arrow-up"></i> Import Excel File</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label"><i class="bi bi-table"></i> Table Name</label>
                        <input name="TableName" class="form-control" placeholder="Enter table name" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label"><i class="bi bi-filetype-xlsx"></i> Excel File</label>
                        <input type="file" name="file" accept=".xls,.xlsx" class="form-control" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-success"><i class="bi bi-file-earmark-arrow-up"></i> Import</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal"> Close</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal: Confirm Delete -->
<div class="modal fade" id="deleteProduct" tabindex="-1" aria-labelledby="deleteProductLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow-sm border-0">
            <form asp-action="Delete" method="post">
                <input type="hidden" name="Id" />
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title" id="deleteProductLabel"><i class="bi bi-trash3"></i> Confirm Deletion</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p class="text-danger fw-bold text-center">Are you sure you want to delete this product?</p>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-danger">Yes, Delete</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal: Error -->
<div class="modal fade" id="errorModal" tabindex="-1" aria-labelledby="errorModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border border-danger shadow-sm">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="errorModalLabel">❗ Deletion Error</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center">
                <p class="text-danger fw-bold" id="errorModalMessage">@TempData["DeleteError"]</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal: General Message -->
<div class="modal fade" id="messageModal" tabindex="-1" aria-labelledby="messageModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow-sm">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title" id="messageModalLabel">ℹ️ Message</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center">
                <p id="modalMessage" class="fs-6 text-dark"></p>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="messageSuccess" tabindex="-1" aria-labelledby="messageModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title" id="messageModalLabel">Notification</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center">
                <p id="modalMessageSuccess" class="fs-6 mb-0"></p>
            </div>
        </div>
    </div>
</div>
<!-- Scripts Section -->
@section Scripts {
    <script>
        $(document).ready(function () {
            // Show delete modal and inject product ID
            $('.btnDelete').click(function (e) {
                e.preventDefault();
                const id = $(this).data('id');
                $('#deleteProduct input[name="Id"]').val(id);
                new bootstrap.Modal(document.getElementById('deleteProduct')).show();
            });

        // Show import modal
        $('.btnImportExcel').click(function () {
            const importModal =  new bootstrap.Modal(document.getElementById('ImportExcel'));
            importModal.show();

                    $('#ImportExcel').on('hidden.bs.modal', function () {
                    $('.modal-backdrop').remove();
                    $('body').removeClass('modal-open');
                    $('body').css('padding-right', '');
                });
        });


       // Show error modal if error exists
         document.addEventListener("DOMContentLoaded", function () {
             const success = @Html.Raw(JsonSerializer.Serialize(TempData["Success"] ?? ""));
             const error = @Html.Raw(JsonSerializer.Serialize(TempData["Error"] ?? ""));

             if (error && error.trim() !== "") {
                 document.getElementById("modalMessage").textContent = error;
                 const modal = new bootstrap.Modal(document.getElementById("messageModal"));
                 modal.show();
             }

             if (success && success.trim() !== "") {
                 document.getElementById("modalMessageSuccess").textContent = success;
                 const modal = new bootstrap.Modal(document.getElementById("messageSuccess"));
                 modal.show();
             }
         });
    </script>
}

