@model ProductStock
@{
    ViewData["Title"] = "Create";
}


<div class="container p-4">


    <div class="flex-column  ">




        <form method="post" asp-controller="ProductStock" asp-action="Create">
            <div class="border p-3 mt4">
                <div class="row pb-2 text-center">
                    <h2 class="text-primary">Create new Stock</h2>
                    <hr />
                </div>


                <div class=" mb-3">
                    <label asp-for="productId" class="form-label">Product</label>
                    <select asp-for="productId" class="form-control" asp-items="ViewBag.Products">
                        <option value="">--Select one--</option>
                    </select>
                    <span asp-validation-for="productId" class="text-danger"></span>
                </div>

                <div class=" mb-3">
                    <label asp-for="storeId" class="form-label">Store</label>
                    <select asp-for="storeId" class="form-control" asp-items="ViewBag.Stores">
                        <option value="">--Select one--</option>
                    </select>
                    <span asp-validation-for="store" class="text-danger"></span>
                </div>

                <div class=" mb-3">
                    <label asp-for="quantity"></label>
                    <input asp-for="quantity" class="form-control" />
                    <span asp-validation-for="quantity" class="text-danger"></span>
                </div>

                <div class="mb-3 text-center ">
                    <button type="submit" class="btn btn-success" style="width:150px">Save</button>
                    <a asp-action="Index" asp-controller="ProductStock" class="btn btn-primary" style="width:150px">Back</a>
                </div>

            </div>
            <div asp-validation-summary="All"></div>
        </form>




    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

