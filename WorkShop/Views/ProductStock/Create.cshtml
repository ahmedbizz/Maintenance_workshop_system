@model ProductStock
@{
    ViewData["Title"] = "Create";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-primary text-white text-center rounded-top-4">
                    <h3 class="mb-0">Create New Stock</h3>
                </div>
                <div class="card-body p-4">
                    <form method="post" asp-controller="ProductStock" asp-action="Create">
                        <div class="mb-3">
                            <label asp-for="productId" class="form-label fw-semibold">Product</label>
                            <select asp-for="productId" class="form-select" asp-items="ViewBag.Products">
                                <option value="">-- Select one --</option>
                            </select>
                            <span asp-validation-for="productId" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="storeId" class="form-label fw-semibold">Store</label>
                            <select asp-for="storeId" class="form-select" asp-items="ViewBag.Stores">
                                <option value="">-- Select one --</option>
                            </select>
                            <span asp-validation-for="storeId" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="quantity" class="form-label fw-semibold">Quantity</label>
                            <input asp-for="quantity" class="form-control" />
                            <span asp-validation-for="quantity" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-center gap-3 mt-4">
                            <button type="submit" class="btn btn-success px-4">Save</button>
                            <a asp-action="Index" asp-controller="ProductStock" class="btn btn-secondary px-4">Back</a>
                        </div>

                        <div class="mt-3">
                            <div asp-validation-summary="All" class="text-danger small"></div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
