@model WorkShop.ViewModel.ProductStockViewModel
@{
    ViewData["Title"] = "Stocks";
}
@using System.Text.Json

<div class="container mt-4">
    <div class="card shadow rounded-4">
        <div class="card-body">
    <!-- Header and Toolbar -->
    <div class="row align-items-center mb-4">
        <div class="col-md-4">
            <h3 class="text-primary"><i class="bi-box-seam me-1"></i> Product Stocks</h3>
        </div>

        <div class="col-md-4">
            <form class="d-flex" method="get">
                <input class="form-control me-2" type="search" name="searchTerm" placeholder="Search by name or part number" value="@Model.SearchTerm">
                <button class="btn btn-outline-primary" type="submit"><i class="bi bi-search"></i></button>
            </form>
        </div>

        <div class="col-md-4 text-end">
            <button class="btn btn-outline-dark me-2 btnImportExcel" data-bs-toggle="modal" data-bs-target="#ImportExcel">
                <i class="bi bi-file-earmark-arrow-up"></i> Import Excel
            </button>
            <a asp-action="Create" asp-controller="ProductStock" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Add Stock
            </a>
        </div>
    </div>

    <!-- Table -->
    <div class="table-responsive">
        <table class="table table-hover shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>Image</th>
                    <th>Product</th>
                    <th>Store</th>
                    <th>Quantity</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var stock in Model.ProductStocks)
                {
                    <tr>
                        <td>
                            <img src="~/images/@stock.product?.imagePath"
                                 class="rounded shadow-sm"
                                 style="width: 50px; height: 50px; object-fit: cover;" />
                        </td>
                        <td>@stock.product?.Name</td>
                        <td>@stock.store?.Name</td>
                        <td>@stock.quantity</td>
                        <td class="text-end">
                            <a asp-controller="ProductStock" asp-action="Create"
                               asp-route-proId="@stock.productId"
                               asp-route-storeId="@stock.storeId"
                               class="btn btn-sm btn-outline-primary me-2">
                                <i class="bi bi-pencil-square"></i>
                            </a>
                            <button class="btn btn-sm btn-outline-danger btnDelete"
                                    data-productid="@stock.productId"
                                    data-storeid="@stock.storeId">
                                        <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @{
        int maxPagesToShow = 5;
        int startPage = Math.Max(1, Model.CurrentPage - maxPagesToShow / 2);
        int endPage = Math.Min(Model.TotalPages, startPage + maxPagesToShow - 1);
        if (endPage - startPage < maxPagesToShow - 1)
        {
            startPage = Math.Max(1, endPage - maxPagesToShow + 1);
        }
    }
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link" href="@Url.Action("Index", new { page = Model.CurrentPage - 1 })">&laquo;</a>
            </li>
            @for (int i = startPage; i <= endPage; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { page = i })">@i</a>
                </li>
            }
            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                <a class="page-link" href="@Url.Action("Index", new { page = Model.CurrentPage + 1 })">&raquo;</a>
            </li>
        </ul>
    </nav>
        </div>
    </div>
</div>
    <!-- Import Excel Modal -->
    <div class="modal fade" id="ImportExcel">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <form asp-action="ImportExcel" asp-controller="Report" method="post" enctype="multipart/form-data">
                    <div class="modal-header bg-dark text-white">
                        <h5 class="modal-title">Import Excel</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Table Name</label>
                            <input name="TableName" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Excel File</label>
                            <input type="file" name="file" accept=".xls,.xlsx" class="form-control" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="submit" class="btn btn-danger">Import</button>
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Delete Confirmation Modal -->
    <div class="modal fade" id="deleteProduct">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-sm">
                <form asp-action="Delete" method="post">
                    <input type="hidden" name="productId" />
                    <input type="hidden" name="storeId" />
                    <div class="modal-header bg-danger text-white">
                        <h5 class="modal-title">Confirm Delete</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        Are you sure you want to delete this stock?
                    </div>
                    <div class="modal-footer">
                        <button type="submit" class="btn btn-danger">Yes</button>
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">No</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Error Modal -->
    <div class="modal fade" id="errorModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-danger">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Error</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p id="errorModalMessage">@TempData["DeleteError"]</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Message Modal -->
    <div class="modal fade" id="messageModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-info">
                <div class="modal-header bg-info text-white">
                    <h5 class="modal-title">Notification</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body text-center">
                    <p id="modalMessage"></p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Delete modal setup
        $('.btnDelete').click(function (e) {
            e.preventDefault();

            const productId = $(this).data('productid');
            const storeId = $(this).data('storeid');

            $('#deleteProduct input[name="productId"]').val(productId);
            $('#deleteProduct input[name="storeId"]').val(storeId);

            const modal = new bootstrap.Modal(document.getElementById('deleteProduct'));
            modal.show();

            $('#deleteProduct').on('hidden.bs.modal', function () {
                $('.modal-backdrop').remove();
                $('body').removeClass('modal-open');
                $('body').css('padding-right', '');
            });
        });

        // Show import modal
        $('.btnImportExcel').click(function () {
            const importModal =  new bootstrap.Modal(document.getElementById('ImportExcel'));
            importModal.show();

                        $('#ImportExcel').on('hidden.bs.modal', function () {
                    $('.modal-backdrop').remove();
                    $('body').removeClass('modal-open');
                    $('body').css('padding-right', '');
                });
        });

        // Show error modal if there's an error
        $(document).ready(function () {
            var errorMessage = '@TempData["DeleteError"]';
            if (errorMessage && errorMessage.trim() !== "") {
                new bootstrap.Modal(document.getElementById('errorModal')).show();
            }

            var success = @Html.Raw(JsonSerializer.Serialize(TempData["Success"]));
            var error = @Html.Raw(JsonSerializer.Serialize(TempData["Error"]));
            var message = success || error;

            if (message && message.trim() !== "") {
                $('#modalMessage').text(message);
                new bootstrap.Modal(document.getElementById('messageModal')).show();
            }
        });
    </script>
}
