@model WorkShop.ViewModel.StoreViewModel
@{
    ViewData["Title"] = "Store";
}
@using System.Text.Json
<div class="container mt-4">
    <div class="card shadow rounded-4">
        <div class="card-body">

            <div class="row mb-3 align-items-center">
                <div class="col-md-4">
                    <h3 class="text-primary"><i class="bi bi-box-seam"></i> Store</h3>
                </div>
                <div class="col-md-4">
                    <form class="d-flex" method="get">
                        <input class="form-control me-2" type="search" name="searchTerm" placeholder="Search by name or part number" value="@Model.searchTerm">
                        <button class="btn btn-outline-primary" type="submit"><i class="bi bi-search"></i></button>
                    </form>
                </div>
                <div class="col-md-4 text-end">
                    <a asp-action="Create" asp-controller="Store" class="btn btn-primary">
                        <i class="bi bi-plus-lg me-1"></i>Create
                    </a>
                </div>
            </div>


   
        <div class="table-responsive">
            <table class="table table-hover shadow-sm align-middle text-center">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Department</th>
                        <th>Created</th>
                        <th>Updated</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var store in Model.stors)
                    {
                        <tr>
                            <td>@store.Id</td>
                            <td>@store.Name</td>
                            <td>@store.department?.Name</td>
                            <td>@store.CreateAt.ToString("yyyy-MM-dd")</td>
                            <td>@store.UpdateAt.ToString("yyyy-MM-dd")</td>
                            <td class="text-center">
                                    <a asp-controller="Store" asp-action="Details" asp-route-Id="@store.Id" class="btn btn-sm btn-outline-success me-1 "> <i class="bi bi-file-earmark-text me-1"></i></a>
                                    <a asp-controller="Store" asp-action="Create" asp-route-Id="@store.Id" class="btn btn-sm btn-outline-secondary me-1">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                <button type="button"
                                        class="btn btn-sm btn-outline-danger btnDelete"
                                        data-id="@store.Id"
                                        data-bs-toggle="modal"
                                        data-bs-target="#deleteModal">
                                    <i class="bi bi-trash3"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
  
        </div>
        <!-- Pagination -->
        @{
            int maxPagesToShow = 5;
            int startPage = Math.Max(1, Model.CurrentPage - maxPagesToShow / 2);
            int endPage = Math.Min(Model.TotalPages, startPage + maxPagesToShow - 1);
            if (endPage - startPage < maxPagesToShow - 1)
            {
                startPage = Math.Max(1, endPage - maxPagesToShow + 1);
            }
        }

        <nav>
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { page = Model.CurrentPage - 1 })">&laquo;</a>
                </li>

                @for (int i = startPage; i <= endPage; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" href="@Url.Action("Index", new { page = i })">@i</a>
                    </li>
                }

                <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { page = Model.CurrentPage + 1 })">&raquo;</a>
                </li>
            </ul>
        </nav>

    </div>
</div>


    <!-- Modal: Confirm Delete -->
    <div class="modal fade" id="deleteProduct" tabindex="-1" aria-labelledby="deleteProductLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-sm border-0">
                <form asp-action="Delete" method="post">
                    <input type="hidden" name="Id" />
                    <div class="modal-header bg-danger text-white">
                        <h5 class="modal-title" id="deleteProductLabel"><i class="bi bi-trash3"></i> Confirm Deletion</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <p class="text-danger fw-bold text-center">Are you sure you want to delete this product?</p>
                    </div>
                    <div class="modal-footer">
                        <button type="submit" class="btn btn-danger">Yes, Delete</button>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Modal: Error -->
    <div class="modal fade" id="errorModal" tabindex="-1" aria-labelledby="errorModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border border-danger shadow-sm">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title" id="errorModalLabel">❗ Deletion Error</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body text-center">
                    <p class="text-danger fw-bold" id="errorModalMessage">@TempData["DeleteError"]</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>
<!-- Modal: General Message -->
<div class="modal fade" id="messageModal" tabindex="-1" aria-labelledby="messageModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow-sm">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title" id="messageModalLabel">ℹ️ Message</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center">
                <p id="modalMessage" class="fs-6 text-dark"></p>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="messageSuccess" tabindex="-1" aria-labelledby="messageModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title" id="messageModalLabel">Notification</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center">
                <p id="modalMessageSuccess" class="fs-6 mb-0"></p>
            </div>
        </div>
    </div>
</div>

    <!-- Scripts Section -->
@section Scripts {
        <script>
         
                // Show delete modal and inject product ID
                $('.btnDelete').click(function (e) {
                    e.preventDefault();
                    const id = $(this).data('id');
                    $('#deleteProduct input[name="Id"]').val(id);
                    new bootstrap.Modal(document.getElementById('deleteProduct')).show();
                });

            // Show import modal
            $('.btnImportExcel').click(function () {
                const importModal =  new bootstrap.Modal(document.getElementById('ImportExcel'));
                importModal.show();

                            $('#ImportExcel').on('hidden.bs.modal', function () {
                        $('.modal-backdrop').remove();
                        $('body').removeClass('modal-open');
                        $('body').css('padding-right', '');
                    });
            });


        document.addEventListener("DOMContentLoaded", function () {
            const success = @Html.Raw(JsonSerializer.Serialize(TempData["Success"] ?? ""));
            const error = @Html.Raw(JsonSerializer.Serialize(TempData["Error"] ?? ""));

            if (error && error.trim() !== "") {
                document.getElementById("modalMessage").textContent = error;
                const modal = new bootstrap.Modal(document.getElementById("messageModal"));
                modal.show();
            }

            if (success && success.trim() !== "") {
                document.getElementById("modalMessageSuccess").textContent = success;
                const modal = new bootstrap.Modal(document.getElementById("messageSuccess"));
                modal.show();
            }
        });
        </script>
}

