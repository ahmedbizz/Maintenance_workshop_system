@model List<SparePartRequest>
@using System.Text.Json
<div class="container mt-5" dir="ltr">


    <!-- Modal: General Message -->
    <div class="modal fade" id="messageModal" tabindex="-1" aria-labelledby="messageModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-sm">
                <div class="modal-header bg-info text-white">
                    <h5 class="modal-title" id="messageModalLabel">ℹ️ Message</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body text-center">
                    <p id="modalMessage" class="fs-6 text-dark"></p>
                </div>
            </div>
        </div>
    </div>
    <div class="modal fade" id="messageSuccess" tabindex="-1" aria-labelledby="messageModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title" id="messageModalLabel">Notification</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body text-center">
                    <p id="modalMessageSuccess" class="fs-6 mb-0"></p>
                </div>
            </div>
        </div>
    </div>
    <!-- Page Title -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="text-primary">Spare Parts Requests</h3>
        <i class="bi bi-tools fs-3 text-muted"></i>
    </div>

    <!-- Requests Table -->
    <div class="table-responsive">
        <table class="table table-hover table-bordered align-middle shadow-sm">
            <thead class="table-dark text-center">
                <tr>
                    <th>Device Serial</th>
                    <th>Requested Parts</th>
                    <th>Request Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody class="text-center">
                @foreach (var req in Model)
                {
                    <tr>
                        <td class="fw-semibold">@req.Device.SerialNumber</td>
                        <td class="text-start">
                            <ul class="list-group list-group-flush">
                                @foreach (var item in req.Items)
                                {
                                    <li class="list-group-item">
                                        <span class="fw-bold">@item.Product.Name</span>
                                        <span class="badge bg-primary rounded-pill ms-2">Qty: @item.Quantity</span>
                                    </li>
                                }
                            </ul>
                        </td>
                        <td>@req.RequestDate.ToString("yyyy-MM-dd")</td>
                        <td>
                            <button class="btn btn-outline-success" onclick="confirmation(@req.Id)">
                                <i class="bi bi-box-arrow-down"></i> Deliver
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Confirm Modal -->
    <div class="modal fade" id="confirmModal" tabindex="-1" aria-labelledby="confirmModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content shadow">
                <div class="modal-header bg-warning">
                    <h5 class="modal-title" id="confirmModalLabel">Confirm Delivery</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    Are you sure you want to mark this request as delivered?
                </div>
                <div class="modal-footer">
                    <form asp-action="PendingDeliveries" asp-controller="Store" method="post">
                        <input type="hidden" name="RequestId" id="confirmItemId" />
                        <button type="submit" class="btn btn-success">Yes, Deliver</button>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmation(id) {
            $('#confirmItemId').val(id);
            const confirmModal = new bootstrap.Modal(document.getElementById('confirmModal'));
            confirmModal.show();
        }


            // Show error modal if error exists
        document.addEventListener("DOMContentLoaded", function () {
            const success = @Html.Raw(JsonSerializer.Serialize(TempData["Success"] ?? ""));
            const error = @Html.Raw(JsonSerializer.Serialize(TempData["Error"] ?? ""));

            if (error && error.trim() !== "") {
                document.getElementById("modalMessage").textContent = error;
                const modal = new bootstrap.Modal(document.getElementById("messageModal"));
                modal.show();
            }

            if (success && success.trim() !== "") {
                document.getElementById("modalMessageSuccess").textContent = success;
                const modal = new bootstrap.Modal(document.getElementById("messageSuccess"));
                modal.show();
            }
        });
    </script>
}
