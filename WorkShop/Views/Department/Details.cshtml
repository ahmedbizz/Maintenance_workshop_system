@model WorkShop.ViewModel.DepartmentDetailsViewModel

<div class="container mt-4">


    <div class="bg-white shadow-sm rounded p-3 mb-4">
        <div class="d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center gap-3">
                <div>
                    <h5 class="mb-0 fw-semibold" style="font-size: 1.1rem;"> <i class="bi bi-building me-1"></i>@Model.Department.Name Employees</h5>
                
                </div>
            </div>
        </div>
    </div>

    <div class="row justify-content-center mb-4">
        <div class="col-md-6">
            <form class="d-flex" method="get">
                <input class="form-control form-control-sm me-2 rounded-pill" type="search" name="searchTerm" placeholder="Search employees..." value="@Model.SearchTerm" style="font-size: 0.9rem;">
                <button class="btn btn-outline-primary rounded-pill px-4 btn-sm" type="submit" style="font-size: 0.9rem;">Search</button>
            </form>
        </div>
    </div>

    @if (Model.Users != null && Model.Users.Any())
    {
        <div class="table-responsive shadow-sm rounded">
            <table class="table table-hover align-middle" style="font-size: 0.9rem;">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Employee</th>
                        <th scope="col">Email</th>
                        <th scope="col">Phone</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        <tr style="cursor:pointer" onclick="location.href='@Url.Action("Create_user_Edite", "User", new { id = user.Id })'">
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <img src="@(user?.imagePath != null ? Url.Content("~/images/" + user.imagePath) : Url.Content("~/images/user.png"))" alt="User Image" class="rounded-circle" style="width: 40px; height: 40px; object-fit: cover;">
                                    <span>@user.FullName</span>
                                </div>
                            </td>
                            <td>@user.Email</td>
                            <td>@user.PhoneNumber</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <nav class="mt-4">
            <ul class="pagination justify-content-center pagination-sm">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" href="@Url.Action("Index", new { page = i })" style="font-size: 0.85rem;">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
    else
    {
        <div class="alert alert-warning text-center" role="alert" style="font-size: 0.9rem;">
            There are no employees in this department.
        </div>
    }

    <div class="text-center mt-4">
        <a asp-action="Index" class="btn btn-outline-danger rounded-pill px-4 btn-sm" style="font-size: 0.9rem;">Back</a>
    </div>
</div>
