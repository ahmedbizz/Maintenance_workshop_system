@model WorkShop.ViewModel.DepartmentDetailsViewModel

<h2 class="text-center">Department employees</h2>

<div>
    <div><h4>Department</h4><h3>@Model.Department.Name</h3></div>
    <hr />
    <h4 class="text-center">Epmloyee in this deoartment</h4>
    <div class="col-6 text-center align-items-center">

        <form class="d-flex">
            <input class="form-control me-sm-2" type="search" name="searchTerm" placeholder="Search" value="@Model.SearchTerm">
            <button class="btn btn-secondary my-2 my-sm-0" type="submit">Search</button>
        </form>
    </div>
    @if (Model.Users != null && Model.Users.Any())
    {
        <table class="table shadow table-hover">
            <thead>
                <tr>
                    <th>Department</th>
                    <th>Email </th>
                    <th>phone</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model.Users)
                {
                    <tr style="cursor:pointer" onclick="location.href='@Url.Action("Create_user_Edite", "User", new { id = user.Id })'">
                        <td>@user.FullName</td>
                        <td>@user.Email</td>
                        <td>@user.PhoneNumber</td>
                    </tr>
                }
            </tbody>
        </table>

            <nav>
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { page = i })">@i</a>
                </li>
            }
        </ul>
    </nav>
    }
    else
    {
        <p>There is no employyes in this department.</p>
    }
</div>

<a asp-action="Index" class=" btn btn-danger">Back</a>
