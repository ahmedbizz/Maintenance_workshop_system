@model IEnumerable<Department>
@{
    ViewData["Title"] = "Index";
}

<div class="row pt-4 align-items-center">

    <div class="col-6">
        <h1 class="text-primary">Departments</h1>
    </div>
    <div class="col-6 text-end align-items-center">
        <a asp-action="Create" asp-controller="Department" class="btn btn-primary"><i class="bi bi-plus-lg"></i>Create</a>

    </div>

    <table class="table tab-content shadow m-4 p-2 table-hover">
        <thead>
            <th>ID</th>
            <th>Name</th>
            <th>Create At</th>
            <th>Update At</th>
        <th></th>
        </thead>
        <tbody>
            @foreach (var department in Model)
            {
                <tr style="cursor:pointer" onclick="location.href='@Url.Action("Details", "Department", new { id = @department.Id })'">
                    <td width="10%">@department.Id</td>
                    <td width="30%">@department.Name</td>
                    <td width="20%">@department.CreateAt</td>
                    <td width="20%">@department.UpdateAt</td>
                    <td width="20%">
                        <a asp-controller="Department" asp-action="Create" asp-route-Id="@department.Id"><i class=" bi-pencil-square text-primary"></i></a>

                        &nbsp;
                        <form asp-action="Delete_Department" method="post" style="display:inline;">
                            <input type="hidden" name="Id" value="@department.Id" />
                            <button type="submit" class="btn btn-link p-0 m-0 border-0 text-danger" onclick="return confirm('Are you sure you want to delete this item?');">
                                <i class="bi-trash3"></i>
                            </button>
                        </form>
                    </td>
                  
    </tr>
            }
        </tbody>

    </table>



</div>

                            