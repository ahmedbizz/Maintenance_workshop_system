@model WorkShop.ViewModel.DepartmentViewModel
@{
    ViewData["Title"] = "Deprtments";
}
@using System.Text.Json
<div class="row pt-4 align-items-center">
    <div class="d-flex align-content-center">
    <div class="col-4">
        <h4 class="text-primary">Departments</h4>
    </div>
    <div class="col-6 text-center align-items-center">

        <form class="d-flex">
            <input class="form-control me-sm-2" type="search" name="searchTerm" placeholder="Search" value="@Model.searchTerm">
            <button class="btn btn-secondary my-2 my-sm-0" type="submit">Search</button>
        </form>
    </div>
    <div class="col-2 text-end align-items-center">

        <button type="button" class="btn btn-primary btnCreateDepartment" data-toggle="modal" data-target="#CreateDepartment"><i class="bi bi-plus-lg"></i>Create</button>
    </div>
    </div>
    <table class="table tab-content shadow m-4 p-2 table-hover">
        <thead>
            <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Create At</th>
            <th>Update At</th>
                <th class="text-center">Actons</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var department in Model.departments)
            {
                <tr>
                    <td width="5%">@department.Id</td>
                    <td width="30%">@department.Name</td>
                    <td width="20%">@department.CreateAt</td>
                    <td width="20%">@department.UpdateAt</td>
                    <td width="25%">


                        <a class="btn btn-outline-success " asp-controller="Report" asp-action="TiketByDepartment" asp-route-Id="@department.Id"><i class="bi bi-file-earmark-text"></i> Report</a>
                        &nbsp;

                        <button type="button" class="btn btn-outline-primary btnEditDepartment" data-toggle="modal" data-target="#EditDepartment" data-url="@Url.Action($"Edit", new { Id = department.Id })"><i class=" bi-pencil-square text-primary"></i> Edit</button>

                        &nbsp;
                        <a class="btn btn-outline-info " asp-controller="Department" asp-action="Details" asp-route-Id="@department.Id"><i class="bi bi-people"></i> Users</a>
                        &nbsp;

                        <button type="button"
                                class="btn btn-link p-0 m-0 border-0 text-danger btnDelete"
                                data-bs-toggle="modal"
                                data-id="@department.Id">
                            <i class="bi-trash3"></i>
                        </button>
                    </td>
                  
    </tr>
            }
        </tbody>

    </table>

    @{
        int maxPagesToShow = 5;
        int startPage = Math.Max(1, Model.CurrentPage - maxPagesToShow / 2);
        int endPage = Math.Min(Model.TotalPages, startPage + maxPagesToShow - 1);

        // تعديل البداية إذا اقتربنا من النهاية
        if (endPage - startPage < maxPagesToShow - 1)
        {
            startPage = Math.Max(1, endPage - maxPagesToShow + 1);
        }
    }

    <nav>
        <ul class="pagination justify-content-center">

            <!-- زر السابق -->
            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link" href="@Url.Action("Index", new { page = Model.CurrentPage - 1 })" aria-label="Previous">
                    <span aria-hidden="true">&laquo;</span>
                </a>
            </li>

            @for (int i = startPage; i <= endPage; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { page = i })">@i</a>
                </li>
            }

            <!-- زر التالي -->
            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                <a class="page-link" href="@Url.Action("Index", new { page = Model.CurrentPage + 1 })" aria-label="Next">
                    <span aria-hidden="true">&raquo;</span>
                </a>
            </li>
        </ul>
    </nav>


</div>


    @await Html.PartialAsync("_Create", new Department())
    <div id="editSection"></div> <!-- سيتم تحميل محتوى _Edit هنا -->

    <div class="modal fade" id="deletDepartment">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form asp-action="Delete_Department" method="post">
                    <input name="Id" hidden />
                    <div class="modal-header">
                        <h5 class="modal-title">Delete Alert !!</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <p>Are you sure to delete this department?</p>
                    </div>
                    <div class="modal-footer">
                        <button type="submit" class="btn btn-danger">Yes</button>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Modal لعرض الخطأ -->
    <div class="modal fade" id="errorModal" tabindex="-1" role="dialog" aria-labelledby="errorModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content border-danger">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title" id="errorModalLabel">Deletion error</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p id="errorModalMessage">@TempData["DeleteError"]</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="messageModal" tabindex="-1" aria-labelledby="messageModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title" id="messageModalLabel">Message</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center">
                <p id="modalMessage"></p>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        // فتح مودال الإنشاء
        $('.btnCreateDepartment').click(() => {
            $('#CreateDepartment').modal('show');
        });

        // فتح مودال التعديل (ajax)
        $('.btnEditDepartment').click(function (e) {
            e.preventDefault();
            const url = $(this).data('url');
            $.get(url, function (data) {
                $('#editSection').html(data);
                $('#EditDepartment').modal('show');
            });
        });

        // فتح مودال الحذف
        $('.btnDelete').click(function (e) {
            e.preventDefault();
            const id = $(this).data('id');
            $('#deletDepartment input[name="Id"]').val(id);
            $('#deletDepartment').modal('show');
        });

        // الحفظ عبر ajax
        $(document).on('submit', '#departmentForm', function (e) {
            e.preventDefault();
            const form = $(this);
            const url = form.attr('action');
            const formData = form.serialize();

            $.post(url, formData)
                                    .done(function (result) {
                                        if (result.success) {
                                            $('.modal').modal('hide');
                                            setTimeout(() => {
                                                location.reload();
                                            }, 300);
                                        } else {
                                            // عرض النموذج مع الأخطاء من السيرفر
                                            if (url.toLowerCase().includes('edit')) {
                                                $('#editSection').html(result);
                                                $('#EditDepartment').modal('show');
                                            } else {
                                                $('#CreateDepartment .modal-content').html($(result).find('.modal-content').html());
                                                $('#CreateDepartment').modal('show');
                                            }
                                        }
                                    });
                         });


                                 $('.btnImportExcel').click(function (e) {
          $('#ImportExcel').modal('show');
        });
            $(document).ready(function () {
            var errorMessage = '@TempData["DeleteError"]';
            if (errorMessage && errorMessage.trim() !== "") {
                var errorModal = new bootstrap.Modal(document.getElementById('errorModal'));
                errorModal.show();
            }
        });

                $(document).ready(function () {
            var success = @Html.Raw(JsonSerializer.Serialize(TempData["Success"]));
            var error = @Html.Raw(JsonSerializer.Serialize(TempData["Error"]));

            let message = success || error;
            if (message && message.trim() !== "") {
                $('#modalMessage').text(message);
                var modal = new bootstrap.Modal(document.getElementById('messageModal'));
                modal.show();
            }
        });

    </script>
}
