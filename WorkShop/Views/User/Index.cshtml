@model WorkShop.ViewModel.UserViewModel
@{
    ViewData["Title"] = "Users";
}
@using System.Text.Json

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary">Users</h2>
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-3 gap-2">
            <!-- Search Form -->
            <form class="d-flex gap-2 align-items-center" method="get">
                <input class="form-control form-control-sm"
                       type="search"
                       name="searchTerm"
                       placeholder="Search..."
                       value="@Model.SearchTerm"
                       style="width: 200px;" />
                <button class="btn btn-outline-secondary btn-sm" type="submit">
                    <i class="bi bi-search me-1"></i> Search
                </button>
            </form>
            <button class="btn btn-outline-info btn-sm me-2 btnImportExcel" data-bs-toggle="modal" data-bs-target="#ImportExcel">
                <i class="bi bi-file-earmark-arrow-up"></i> Import
            </button>
            <a asp-action="Create_user_Edite" asp-controller="User" class="btn btn-sm btn-primary">
                <i class="bi bi-plus-lg"></i> Create
            </a>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-hover table-bordered align-middle shadow-sm">
            <thead class="table-dark text-center">
                <tr>
                    <th>Image</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Departments</th>
                    <th>Updated At</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model.users)
                {
                    <tr class="text-center">
                        <td>
                            <img src="~/images/@user.imagePath" class="rounded-circle shadow-sm" style="width: 45px; height: 45px; object-fit: cover;">
                        </td>
                        <td>@user.FullName</td>
                        <td>@user.Email</td>
                        <td>
                            @foreach (var dep in user.UserDepartments)
                            {
                                <span class="badge bg-light text-dark border border-secondary me-1">@dep.Department.Name</span>
                            }
                        </td>
                        <td>@user.UpdateAt.ToString("yyyy-MM-dd")</td>
                        <td>
                            <div class="d-flex justify-content-center gap-2">
                                <a class="btn btn-sm btn-outline-success" asp-controller="Report" asp-action="UserMintenanceHistory" asp-route-Id="@user.Id">
                                    <i class="bi bi-file-earmark-text"></i>
                                </a>
                                <a class="btn btn-sm btn-outline-primary" asp-controller="User" asp-action="Create_user_Edite" asp-route-Id="@user.Id">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                <button type="button" class="btn btn-sm btn-outline-danger btnDelete" data-id="@user.Id">
                                    <i class="bi bi-trash3"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* Pagination *@
    @{
        int maxPagesToShow = 5;
        int startPage = Math.Max(1, Model.CurrentPage - maxPagesToShow / 2);
        int endPage = Math.Min(Model.TotalPages, startPage + maxPagesToShow - 1);
        if (endPage - startPage < maxPagesToShow - 1)
        {
            startPage = Math.Max(1, endPage - maxPagesToShow + 1);
        }
    }
    <nav>
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link" href="@Url.Action("Index", new { page = Model.CurrentPage - 1 })">&laquo;</a>
            </li>
            @for (int i = startPage; i <= endPage; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { page = i })">@i</a>
                </li>
            }
            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                <a class="page-link" href="@Url.Action("Index", new { page = Model.CurrentPage + 1 })">&raquo;</a>
            </li>
        </ul>
    </nav>
</div>
@* //Import From Excel *@
<div class="modal fade" id="ImportExcel">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="ImportExcel" asp-controller="Report" method="post" enctype="multipart/form-data">
                <div class="modal-header">
                    <h5 class="modal-title">Import Excel !!</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label>Table Name:</label>
                        <input name="TableName" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label>Excel file:</label>
                        <input type="file" name="file" accept=".xls,.xlsx" class="form-control" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-danger">Import</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </form>
        </div>
    </div>
</div>


<div class="modal fade" id="messageModal" tabindex="-1" aria-labelledby="messageModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title" id="messageModalLabel">Message</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center">
                <p id="modalMessage"></p>
            </div>
        </div>
    </div>
</div>


    <div class="modal fade" id="deleteUser">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form asp-action="Delete_user" method="post">
                    <input name="Id" hidden />
                    <div class="modal-header">
                        <h5 class="modal-title">Delete Alert !!</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <p>Are you sure to delete this User?</p>
                    </div>
                    <div class="modal-footer">
                        <button type="submit" class="btn btn-danger">Yes</button>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Modal لعرض الخطأ -->
    <div class="modal fade" id="errorModal" tabindex="-1" role="dialog" aria-labelledby="errorModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content border-danger">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title" id="errorModalLabel">Deletion error</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p id="errorModalMessage">@TempData["DeleteError"]</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script>
                    // فتح مودال الحذف
        $('.btnDelete').click(function (e) {
            e.preventDefault();
            const id = $(this).data('id');
            $('#deleteUser input[name="Id"]').val(id);
            $('#deleteUser').modal('show');
        });

        $('.btnImportExcel').click(function (e) {
          $('#ImportExcel').modal('show');
        });
            $(document).ready(function () {
            var errorMessage = '@TempData["DeleteError"]';
            if (errorMessage && errorMessage.trim() !== "") {
                var errorModal = new bootstrap.Modal(document.getElementById('errorModal'));
                errorModal.show();
            }
        });

                $(document).ready(function () {
            var success = @Html.Raw(JsonSerializer.Serialize(TempData["Success"]));
            var error = @Html.Raw(JsonSerializer.Serialize(TempData["Error"]));

            let message = success || error;
            if (message && message.trim() !== "") {
                $('#modalMessage').text(message);
                var modal = new bootstrap.Modal(document.getElementById('messageModal'));
                modal.show();
            }
        });
    </script>
    }