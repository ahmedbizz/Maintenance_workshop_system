@model Device
@{
    ViewData["Title"] = "DetailsPartsRequests";
}

@using Microsoft.AspNetCore.Identity
@using WorkShop.Enums
@inject UserManager<User> UserManager
@inject SignInManager<User> SignInManager
@inject WorkShop.Repository.Base.IUnitOfWork _unitOfWork
@{
    var engs = await UserManager.GetUsersInRoleAsync(Roles.Engineer);
}

<div class="container mt-4">
    <h2 class="text-primary">Details Parts Requests </h2>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Dvice:</dt>
        <dd class="col-sm-9">@Model.Product?.Name</dd>

        <dt class="col-sm-3"> S/N:</dt>
        <dd class="col-sm-9">@Model.SerialNumber</dd>

        <dt class="col-sm-3">Department:</dt>
        <dd class="col-sm-9">@Model.Department?.Name</dd>
        <dt class="col-sm-3"> Technician:</dt>
        <dd class="col-sm-9">@Model.Technician?.FullName</dd>
        <dt class="col-sm-3"> Engineer Approval:</dt>
        <dd class="col-sm-9">@engs.FirstOrDefault(eng => eng.Id == Model.MaintenanceCard?.EngineerId).FullName</dd>
        <dt class="col-sm-3">Technician report:</dt>
        <dd class="col-sm-9">@Model.MaintenanceCard?.TechnicianReport</dd>
    </dl>
    <h4 class="text-secondary"> Requested parts</h4>
    @if (Model.SparePartRequests != null && Model.SparePartRequests.Any())
    {
        var request = Model.SparePartRequests.FirstOrDefault();

        if (request?.Items != null && request.Items.Any())
        {
            <table class="table table-hover shadow">
                <thead>
                    <tr>
                        <th> Part</th>
                        <th>Quantity</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in request.Items)
                    {
                        <tr>
                            <td>@item.Product?.Name</td>
                            <td>@item.Quantity</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="alert alert-warning text-center">No parts Requested .</div>
        }
    }
    else
    {
        <div class="alert alert-secondary text-center">Call Administartor somthin rong!.</div>
    }

<a class="btn btn-primary btn-sm" asp-action="ReviewPartsRequestsByOfficer" asp-controller="Officer">Back</a>

                        <form method="post" asp-action="ApproveByOfficer" asp-controller="Officer" asp-route-id="@Model.Id" style="display:inline-block">
                            <button class="btn btn-success btn-sm">Aprrove</button>
                        </form>
                        <form method="post" asp-action="RejectByOfficer" asp-controller="Officer" asp-route-id="@Model.Id" style="display:inline-block">
                            <button class="btn btn-danger btn-sm">Reject</button>
                        </form>
</div>

