@model List<Device>
@using Microsoft.AspNetCore.Identity
@using WorkShop.Enums
@inject UserManager<User> UserManager
@inject SignInManager<User> SignInManager
@inject WorkShop.Repository.Base.IUnitOfWork _unitOfWork

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary">Pending Requests for Officer Approval</h2>
        <i class="bi bi-shield-check text-success fs-3"></i>
    </div>

    <div class="table-responsive rounded shadow-sm">
        <table class="table  table-hover align-middle mb-0">
            <thead class="table-dark text-center">
                <tr>
                    <th>Device</th>
                    <th>Serial Number</th>
                    <th>Technician</th>
                    <th>Engineer</th>
                    <th>Report</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @{
                    var engineers = await UserManager.GetUsersInRoleAsync(Roles.Engineer);
                }

                @foreach (var device in Model)
                {
                    var engineer = engineers.FirstOrDefault(e => e.Id == device.MaintenanceCard?.EngineerId);

                    <tr class="text-center"
                        style="cursor: pointer;"
                        data-url="@Url.Action("DetailsPartsRequestsByOfficer", "Officer", new { id = device.Id })"
                        onclick="window.location.href = this.dataset.url">

                        <td>@device.Product?.Name</td>
                        <td>@device.SerialNumber</td>
                        <td>@device.Technician?.FullName</td>
                        <td>@engineer?.FullName</td>
                        <td class="text-wrap text-start" style="max-width: 250px;">@device.MaintenanceCard?.TechnicianReport</td>
                        <td>
                            <div class="d-flex justify-content-center gap-2">
                                <form method="post" asp-action="ApproveByOfficer" asp-controller="Officer" asp-route-id="@device.Id" class="m-0">
                                    <button type="submit" class="btn btn-success btn-sm">
                                        <i class="bi bi-check-circle me-1"></i> Approve
                                    </button>
                                </form>
                                <form method="post" asp-action="RejectByOfficer" asp-controller="Officer" asp-route-id="@device.Id" class="m-0">
                                    <button type="submit" class="btn btn-danger btn-sm">
                                        <i class="bi bi-x-circle me-1"></i> Reject
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal: General Message -->
<div class="modal fade" id="messageModal" tabindex="-1" aria-labelledby="messageModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow-sm">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title" id="messageModalLabel">ℹ️ Message</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center">
                <p id="modalMessage" class="fs-6 text-dark"></p>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="messageSuccess" tabindex="-1" aria-labelledby="messageModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title" id="messageModalLabel">Notification</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center">
                <p id="modalMessageSuccess" class="fs-6 mb-0"></p>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script>



      // Show error modal if error exists
        document.addEventListener("DOMContentLoaded", function () {
            const success = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["Success"]));
            const error = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["Error"]));

            if (error && error.trim() !== "") {
                document.getElementById("modalMessage").textContent = error;
                const modal = new bootstrap.Modal(document.getElementById("messageModal"));
                modal.show();
            }

            if (success && success.trim() !== "") {
                document.getElementById("modalMessageSuccess").textContent = success;
                const modal = new bootstrap.Modal(document.getElementById("messageSuccess"));
                modal.show();
            }
        });


    </script>
    <style>
        body {
            background-color: #f8f9fa;
        }

        .table td, .table th {
            vertical-align: middle;
        }
    </style>

}

