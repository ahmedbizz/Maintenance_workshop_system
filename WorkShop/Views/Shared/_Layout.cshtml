@using Microsoft.AspNetCore.Identity
@using WorkShop.Enums
@inject UserManager<User> UserManager
@inject SignInManager<User> SignInManager
@inject WorkShop.Repository.Base.IUnitOfWork _unitOfWork

@{
    var currentUser = UserManager.GetUserAsync(User).Result;
    var notifications = new List<Notification>();
    int unreadCount = 0;

    if (currentUser != null)
    {
        notifications = _unitOfWork.notifications.FindAll()
            .Where(n => n.ReceiverId == currentUser.Id && !n.IsRead)
            .OrderByDescending(n => n.CreatedAt)
            .ToList();

        unreadCount = notifications.Count;
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WorkShop</title>
    <link rel="stylesheet" href="~/css/FlatlyStayle.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WorkShop.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <style>
        .navbar .dropdown-toggle .rounded-circle:hover {
            box-shadow: 0 0 5px rgba(0, 0, 0, 0.3);
            transition: 0.3s ease-in-out;
        }
    </style>
</head>
<body>
    <header>
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger text-center">
                @TempData["Error"]
            </div>
        }

        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom shadow-sm mb-3">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">WorkShop</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                        @if (User.Identity.IsAuthenticated)
                        {
                            @if (User.IsInRole(Roles.Admin))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="#" role="button" aria-haspopup="true" aria-expanded="false">Managmenet</a>
                                    <ul class="dropdown-menu">
                                        <li><a class="dropdown-item" asp-controller="Department" asp-action="Index">Departmet</a></li>
                                        <li><a class="dropdown-item" asp-controller="User" asp-action="Index">Users</a></li>
                                        <li><a class="dropdown-item" asp-controller="Group" asp-action="Index">Groups</a></li>
                                        <li><a class="dropdown-item" asp-controller="Role" asp-action="ListRole">Roles</a></li>
                                        <li><a class="dropdown-item" asp-controller="Role" asp-action="ListUsers"> Manage Roles</a></li>
                                    </ul>
                                </li>
                            }
                            @* روابط بحسب الدور *@
                            @if (User.IsInRole(Roles.Engineer) || User.IsInRole(Roles.Admin))
                            {

                                <li class="nav-item"><a class="nav-link" asp-controller="Department" asp-action="Index">Departmet</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Device" asp-action="AddDevice">Maintenance ticket </a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Engineer" asp-action="ReviewPartsRequests"> Spare parts requests </a></li>
                            }
                            @if (User.IsInRole(Roles.Technion) || User.IsInRole(Roles.Engineer) || User.IsInRole(Roles.Officer) || User.IsInRole(Roles.Admin))
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="Device" asp-action="Index">Devices</a></li>
                            }
                            @if (User.IsInRole(Roles.Technion) || User.IsInRole(Roles.Admin))
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="Device" asp-action="TechnicionDevices">My Devices</a></li>
                            }
                            @if (User.IsInRole(Roles.Officer) || User.IsInRole(Roles.Admin))
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="Officer" asp-action="ReviewPartsRequestsByOfficer">Spare parts requests</a></li>
                            }
                            @if (User.IsInRole(Roles.StoreKeeper) || User.IsInRole(Roles.Admin))
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="Store" asp-action="PendingDeliveries">Spare parts requests</a></li>
                            }
                            @if (User.IsInRole(Roles.StoreKeeper) || User.IsInRole(Roles.Officer) || User.IsInRole(Roles.Admin))
                            {
                              
                                <li class="nav-item"><a class="nav-link" asp-controller="Store" asp-action="Index">WareHuose</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Product" asp-action="Index">Products</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="ProductStock" asp-action="Index">Stoks</a></li>
                            }
                        }

                    </ul>

                    <ul class="navbar-nav mb-2 mb-lg-0">
                        @* <li class="nav-item">
                            <div class="text-end me-2">
                                <a class="btn btn-sm btn-outline-secondary me-1" href="?culture=ar&ui-culture=ar">العربية</a>
                                <a class="btn btn-sm btn-outline-secondary" href="?culture=en&ui-culture=en">English</a>
                            </div>
                        </li> *@

                        @if (User.Identity.IsAuthenticated)
                        {
                            <div class="d-flex align-items-center">
                            @* إشعارات *@
                            <li class="nav-item dropdown mx-2">
                                <a class="nav-link position-relative" href="#" id="notificationDropdown" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-bell"></i>
                                    @if (unreadCount > 0)
                                    {
                                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                            @unreadCount
                                        </span>
                                    }
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="notificationDropdown" style="min-width: 300px; background-color:lightgrey">
                                    @if (notifications.Any())
                                    {

                                        @foreach (var n in notifications)
                                        {
                                            string url = "#";
                                            if (n.DeviceId > 0)
                                            {
                                                // تحديد الرابط حسب نوع المستخدم
                                                if (User.IsInRole(Roles.Officer))
                                                {
                                                    url = Url.Action("ReviewPartsRequestsByOfficer", "Officer");
                                                }
                                                if (User.IsInRole(Roles.Engineer))
                                                {
                                                    url = Url.Action("ReviewPartsRequests","Engineer");
                                                }
                                                else if (User.IsInRole(Roles.Technion))
                                                {
                                                    url = Url.Action("TechnicionDevices", "Device");
                                                }
                                            }
                                          
                                                <div class="toast show" role="alert">
                                                    <div class="toast-header">
                                                        <strong class="me-auto text-success">@n.Title</strong>
                                                        <small class="text-info">@n.CreatedAt.ToString("yyyy-MM-dd HH:mm")</small>
                                                        <form asp-action="DeleteNotification" asp-controller="Notification" method="post">
                                                            <input type="hidden" name="Id" value="@n.Id" />
                                                            <input hidden name="curentUrl" value="@Context.Request.Path"/>
                                                            <button type="submit" class="btn-close btn-danger ms-2 mb-1"  aria-label="Close">
                                                                <span aria-hidden="true"></span>
                                                            </button>
                                                        </form>

                                                    </div>
                                                    <div class="toast-body"
                                                         data-url=@url
                                                         onclick="window.location.href = this.dataset.url"
                                                         style="cursor: pointer;">
                                                        @n.Message
                                                    </div>
                                                </div>

                                         
                                        }
                                    }
                                    else
                                    {
                                        <li><span class="dropdown-item text-muted">Notifications it is empty</span></li>
                                    }
                            
                                </ul>
                            </li>


         

                            @* صورة واسم المستخدم *@
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                    <img src="@(currentUser?.imagePath != null ? Url.Content("~/images/" + currentUser.imagePath) : Url.Content("~/images/user.png"))"
                                         class="rounded-circle me-2 border"
                                         style="width: 40px; height: 40px; object-fit: cover;" />
                                    <span>
                                        @((currentUser?.FullName?.Length > 15) ? currentUser.FullName.Substring(0, 15) + "..." : currentUser?.FullName)
                                    </span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">

                                    <li> <a asp-controller="User" class="dropdown-item text-primary" asp-action="Create_user_Edite" asp-route-Id="@currentUser.Id">user profile </a></li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post">
                                            <button class="dropdown-item text-danger"> Logout</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                    </div>
                        }
                        else
                        {
                    <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Login"> Login </a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Register"> Register</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-auto">
        <div class="container">
            &copy; 2025 - WorkShop - <a asp-controller="Home" asp-action="Privacy">سياسة الخصوصية</a>
        </div>
    </footer>
    <script>
        function deleteNotification(id) {
            fetch(`/Notification/DeleteNotification/${id}`, {
                method: 'POST',
                headers: {
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                }
            })
            .then(response => {
                if (response.ok) {
                    // حذف العنصر من الصفحة بدون تحديث
                    const element = document.getElementById(`notification-${id}`);
                    if (element) element.remove();
                }
            });
        }
    </script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
