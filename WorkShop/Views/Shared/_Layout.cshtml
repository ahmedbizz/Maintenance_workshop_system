@using Microsoft.AspNetCore.Identity
@using WorkShop.Enums
@inject UserManager<User> UserManager
@inject SignInManager<User> SignInManager
@inject WorkShop.Repository.Base.IUnitOfWork _unitOfWork

@{
    var currentUser = UserManager.GetUserAsync(User).Result;
    var notifications = new List<Notification>();
    int unreadCount = 0;

    if (currentUser != null)
    {
        notifications = _unitOfWork.notifications.FindAll()
            .Where(n => n.ReceiverId == currentUser.Id && !n.IsRead)
            .OrderByDescending(n => n.CreatedAt)
            .Take(5)
            .ToList();

        unreadCount = notifications.Count;
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WorkShop</title>
    <link rel="stylesheet" href="~/css/FlatlyStayle.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WorkShop.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <style>
        .navbar .dropdown-toggle .rounded-circle:hover {
            box-shadow: 0 0 5px rgba(0, 0, 0, 0.3);
            transition: 0.3s ease-in-out;
        }
    </style>
</head>
<body>
    <header>
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger text-center">
                @TempData["Error"]
            </div>
        }

        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom shadow-sm mb-3">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">WorkShop</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                        @if (User.Identity.IsAuthenticated)
                        {
                            @* روابط بحسب الدور *@
                            @if (User.IsInRole("Engineer"))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">الإدارة</a>
                                    <ul class="dropdown-menu">
                                        <li><a class="dropdown-item" asp-controller="Department" asp-action="Index">الأقسام</a></li>
                                        <li><a class="dropdown-item" asp-controller="User" asp-action="Index">المستخدمين</a></li>
                                        <li><a class="dropdown-item" asp-controller="Group" asp-action="Index">المجموعات</a></li>
                                        <li><a class="dropdown-item" asp-controller="Role" asp-action="ListRole">الصلاحيات</a></li>
                                        <li><a class="dropdown-item" asp-controller="Role" asp-action="ListUsers">توزيع الصلاحيات</a></li>
                                    </ul>
                                </li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Store" asp-action="Index">المخزن</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Product" asp-action="Index">المنتجات</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="ProductStock" asp-action="Index">المخزون</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Device" asp-action="AddDevice">تذكرة صيانة</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Device" asp-action="ReviewPartsRequests">طلبات قطع الغيار</a></li>
                            }
                            @if (User.IsInRole("Technion") || User.IsInRole("Engineer"))
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="Device" asp-action="Index">الأجهزة</a></li>
                            }
                            @if (User.IsInRole("Technion"))
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="Device" asp-action="TechnicionDevices">أجهزتي</a></li>
                            }
                            @if (User.IsInRole("Officer"))
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="Device" asp-action="ReviewPartsRequestsByOfficer">طلبات قطع الغيار</a></li>
                            }
                            @if (User.IsInRole("StoreKeeper"))
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="Device" asp-action="PendingDeliveries">طلبات  صرف قطع الغيار</a></li>
                            }
                        }

                    </ul>

                    <ul class="navbar-nav mb-2 mb-lg-0">
                        @* <li class="nav-item">
                            <div class="text-end me-2">
                                <a class="btn btn-sm btn-outline-secondary me-1" href="?culture=ar&ui-culture=ar">العربية</a>
                                <a class="btn btn-sm btn-outline-secondary" href="?culture=en&ui-culture=en">English</a>
                            </div>
                        </li> *@

                        @if (User.Identity.IsAuthenticated)
                        {
                            <div class="d-flex align-items-center">
                            @* إشعارات *@
                            <li class="nav-item dropdown mx-2">
                                <a class="nav-link position-relative" href="#" id="notificationDropdown" role="button" data-bs-toggle="dropdown">
                                    🔔
                                    @if (unreadCount > 0)
                                    {
                                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                            @unreadCount
                                        </span>
                                    }
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="notificationDropdown" style="min-width: 300px;">
                                    @if (notifications.Any())
                                    {

                                        @foreach (var n in notifications)
                                        {
                                            string url = "#";
                                            if (n.DeviceId > 0)
                                            {
                                                // تحديد الرابط حسب نوع المستخدم
                                                if (User.IsInRole("Officer"))
                                                {
                                                    url = Url.Action("ReviewPartsRequestsByOfficer", "Device");
                                                }
                                                if (User.IsInRole("Engineer"))
                                                {
                                                    url = Url.Action("ReviewPartsRequests", "Device");
                                                }
                                                else if (User.IsInRole("Technion"))
                                                {
                                                    url = Url.Action("TechnicionDevices", "Device");
                                                }
                                            }
                                            <li class="dropdown-item @(n.IsRead ? "bg-light" : "bg-light")"
                                                data-url=@url
                                                onclick="window.location.href = this.dataset.url"
                                                style="cursor: pointer;">
                                                <div class="d-flex justify-content-between">
                                                <div>
                                                    <strong>@n.Title</strong><br />
                                                    @n.Message <br />
                                                    <small class="text-muted">@n.CreatedAt.ToString("yyyy-MM-dd HH:mm")</small>
                                       
                                                </div>
                                                <a class="text-danger"
                                                   onclick="deleteNotification(@n.Id)">
                                                        <i class="bi bi-x-lg"></i>
                                                </a>
                                                </div>
                                            </li>
                                        }
                                    }
                                    else
                                    {
                                        <li><span class="dropdown-item text-muted">لا توجد إشعارات جديدة</span></li>
                                    }
                                    <li>
                                        <a class="dropdown-item text-center text-primary" asp-controller="Notification" asp-action="Index">عرض الكل</a>
                                    </li>
                                </ul>
                            </li>

                            @* صورة واسم المستخدم *@
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                    <img src="@(currentUser?.imagePath != null ? Url.Content("~/images/" + currentUser.imagePath) : Url.Content("~/images/user.png"))"
                                         class="rounded-circle me-2 border"
                                         style="width: 40px; height: 40px; object-fit: cover;" />
                                    <span>@currentUser?.UserName</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                    <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile">الملف الشخصي</a></li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post">
                                            <button class="dropdown-item text-danger">تسجيل الخروج</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                    </div>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Login">تسجيل الدخول</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Register">إنشاء حساب</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-auto">
        <div class="container">
            &copy; 2025 - WorkShop - <a asp-controller="Home" asp-action="Privacy">سياسة الخصوصية</a>
        </div>
    </footer>
    <script>
        function deleteNotification(id) {
            fetch(`/Device/DeleteNotification/${id}`, {
                method: 'POST',
                headers: {
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                }
            })
            .then(response => {
                if (response.ok) {
                    // حذف العنصر من الصفحة بدون تحديث
                    const element = document.getElementById(`notification-${id}`);
                    if (element) element.remove();
                }
            });
        }
    </script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
