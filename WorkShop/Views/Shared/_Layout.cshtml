@using Microsoft.AspNetCore.Identity
@using WorkShop.Enums
@inject UserManager<User> UserManager
@inject SignInManager<User> SignInManager
@inject WorkShop.Repository.Base.IUnitOfWork _unitOfWork

@{
    var currentUser = UserManager.GetUserAsync(User).Result;
    var notifications = new List<Notification>();
    int unreadCount = 0;

    if (currentUser != null)
    {
        notifications = _unitOfWork.notifications.FindAll()
            .Where(n => n.ReceiverId == currentUser.Id && !n.IsRead)
            .OrderByDescending(n => n.CreatedAt)
            .ToList();

        unreadCount = notifications.Count;
    }

    string displayName = currentUser?.FullName?.Length > 15
        ? currentUser.FullName.Substring(0, 15) + "..."
        : currentUser?.FullName;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WorkShop</title>

    <link rel="stylesheet" href="~/css/FlatlyStayle.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WorkShop.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">

<style>
    .nav-link:hover {
        color: #0d6efd !important;
        text-decoration: underline;
        transition: all 0.3s ease-in-out;
    }

    .dropdown-menu a:hover {
        background-color: #f8f9fa;
        color: #0d6efd;
    }

    body {
        font-family: 'Segoe UI', sans-serif;
        font-size: 14.5px;
    }
</style>
</head>
<body>
    <header>
<nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom shadow-sm mb-3">
    <div class="container-fluid px-4">
        <a class="navbar-brand fw-bold text-dark" asp-controller="Home" asp-action="Index">WorkShop</a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="mainNavbar">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0 gap-3">
                @if (User.Identity.IsAuthenticated)
                {
                    @if (User.IsInRole(Roles.Admin))
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle fw-semibold text-dark" data-bs-toggle="dropdown" href="#">Management</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Department" asp-action="Index">Departments</a></li>
                                <li><a class="dropdown-item" asp-controller="User" asp-action="Index">Users</a></li>
                                <li><a class="dropdown-item" asp-controller="Group" asp-action="Index">Groups</a></li>
                                <li><a class="dropdown-item" asp-controller="Role" asp-action="ListRole">Roles</a></li>
                                <li><a class="dropdown-item" asp-controller="Role" asp-action="ListUsers">Manage Roles</a></li>
                            </ul>
                        </li>
                    }

                    @if (User.IsInRole(Roles.Engineer) || User.IsInRole(Roles.Admin))
                    {
                        <li class="nav-item"><a class="nav-link text-dark" asp-controller="Device" asp-action="AddDevice">Maintenance Ticket</a></li>
                        <li class="nav-item"><a class="nav-link text-dark" asp-controller="Engineer" asp-action="ReviewPartsRequests">Spare Parts Requests</a></li>
                    }

                    @if (User.IsInRole(Roles.Technion) || User.IsInRole(Roles.Engineer) || User.IsInRole(Roles.Officer) || User.IsInRole(Roles.Admin))
                    {
                        <li class="nav-item"><a class="nav-link text-dark" asp-controller="Device" asp-action="Index">Devices</a></li>
                    }

                    @if (User.IsInRole(Roles.Technion))
                    {
                        <li class="nav-item"><a class="nav-link text-dark" asp-controller="Device" asp-action="TechnicionDevices">My Devices</a></li>
                    }

                    @if (User.IsInRole(Roles.Officer) || User.IsInRole(Roles.Admin))
                    {
                        <li class="nav-item"><a class="nav-link text-dark" asp-controller="Officer" asp-action="ReviewPartsRequestsByOfficer">Parts Requests</a></li>
                    }

                    @if (User.IsInRole(Roles.StoreKeeper) || User.IsInRole(Roles.Admin))
                    {
                        <li class="nav-item"><a class="nav-link text-dark" asp-controller="Store" asp-action="PendingDeliveries">Pending</a></li>
                        <li class="nav-item"><a class="nav-link text-dark" asp-controller="Store" asp-action="Index">Warehouse</a></li>
                        <li class="nav-item"><a class="nav-link text-dark" asp-controller="Product" asp-action="Index">Products</a></li>
                        <li class="nav-item"><a class="nav-link text-dark" asp-controller="ProductStock" asp-action="Index">Stocks</a></li>
                    }
                }
            </ul>

            <ul class="navbar-nav align-items-center gap-3">
                @if (User.Identity.IsAuthenticated)
                {
                    <!-- Notifications -->
                    <li class="nav-item dropdown">
                        <a class="nav-link position-relative text-dark" href="#" data-bs-toggle="dropdown">
                            <i class="bi bi-bell fs-5"></i>
                            @if (unreadCount > 0)
                            {
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                    @unreadCount
                                </span>
                            }
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end" style="min-width: 320px;">
                            @if (notifications.Any())
                            {
                                @foreach (var n in notifications)
                                {
                                    string url = "#";
                                    if (n.DeviceId > 0)
                                    {
                                        url = User.IsInRole(Roles.Officer)
                                            ? Url.Action("ReviewPartsRequestsByOfficer", "Officer")
                                            : User.IsInRole(Roles.Engineer)
                                                ? Url.Action("ReviewPartsRequests", "Engineer")
                                                : Url.Action("TechnicionDevices", "Device");
                                    }

                                    <div class="toast show my-2 shadow-sm" role="alert">
                                        <div class="toast-header bg-light">
                                            <strong class="me-auto text-primary">@n.Title</strong>
                                            <small class="text-muted">@n.CreatedAt.ToString("yyyy-MM-dd HH:mm")</small>
                                            <form asp-action="DeleteNotification" asp-controller="Notification" method="post" class="ms-2">
                                                <input type="hidden" name="Id" value="@n.Id" />
                                                <input type="hidden" name="curentUrl" value="@Context.Request.Path" />
                                                <button type="submit" class="btn-close"></button>
                                            </form>
                                        </div>
                                        <div class="toast-body" onclick="window.location.href='@url'" style="cursor:pointer;">
                                            @n.Message
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <li><span class="dropdown-item text-muted">No notifications</span></li>
                            }
                        </ul>
                    </li>

                    <!-- User Info -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" data-bs-toggle="dropdown">
                            <img src="@(currentUser?.imagePath != null ? Url.Content("~/images/" + currentUser.imagePath) : Url.Content("~/images/user.png"))"
                                 class="rounded-circle border shadow-sm"
                                 style="width: 36px; height: 36px;" />
                            <span class="fw-semibold">@displayName</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item text-primary" asp-controller="User" asp-action="Create_user_Edite" asp-route-id="@currentUser.Id">Profile</a></li>
                            <li><hr class="dropdown-divider" /></li>
                            <li>
                                <form asp-controller="Account" asp-action="Logout" method="post">
                                    <button class="dropdown-item text-danger">Logout</button>
                                </form>
                            </li>
                        </ul>
                    </li>
                }
                else
                {
                    <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Login">Login</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Register">Register</a></li>
                }
            </ul>
        </div>
    </div>
</nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-auto">
        <div class="container text-center py-3">
            &copy; 2025 - WorkShop - <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
