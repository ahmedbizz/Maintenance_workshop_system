@model WorkShop.ViewModel.DeviceDetailsViewModel
@using WorkShop.Enums

@{
    var status = (MaintenanceStatus)Enum.Parse(typeof(MaintenanceStatus), Model.DeviceStatus ?? "Pending");

    string GetStatusColor(MaintenanceStatus s) => s switch
    {
        MaintenanceStatus.Pending => "secondary",
        MaintenanceStatus.AwaitingEngineer => "warning",
        MaintenanceStatus.ApprovedByEngineer => "primary",
        MaintenanceStatus.AwaitingOfficer => "info",
        MaintenanceStatus.ApprovedByOfficer => "success",
        MaintenanceStatus.RejectedByEngineer => "danger",
        MaintenanceStatus.RejectedByOfficer => "danger",
        MaintenanceStatus.Repaired => "success",
        MaintenanceStatus.Closed => "dark",
        _ => "secondary"
    };
}

<div class="container mt-4" dir="ltr">
    @if (TempData["Massege"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            <strong>Warning!</strong> @TempData["Massege"]
            <button type="button" class="btn-close float-start" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <h2 class="text-primary">Device Details</h2>
    <hr />

    <dl class="row">
        <dt class="col-sm-2">Device:</dt>
        <dd class="col-sm-4">@Model.ProductName</dd>

        <dt class="col-sm-2">Status:</dt>
        <dd class="col-sm-4">
            <span class="badge bg-@GetStatusColor(status) p-2">@status</span>
        </dd>

        <dt class="col-sm-2">Serial Number:</dt>
        <dd class="col-sm-4">@Model.SerialNumber</dd>

        <dt class="col-sm-2">Department:</dt>
        <dd class="col-sm-4">@Model.DepartmentName</dd>

        <dt class="col-sm-2">Fault Date:</dt>
        <dd class="col-sm-4">@Model.FaultDate</dd>

        <dt class="col-sm-2">Report:</dt>
        <dd class="col-sm-10">@Model.TechnicianReport</dd>

        <dd class="col-sm-12 mt-2">
            <a asp-action="DeviceHistory" asp-controller="Report" asp-route-SN="@Model.SerialNumber" asp-route-ProductName="@Model.ProductName" asp-route-DepartmentId="@Model.DepartmentName" class="btn btn-outline-info">
                View Maintenance History
            </a>
        </dd>
    </dl>

    <hr />

    <h4>Suggestions for Repair</h4>
    @if (Model.Suggestions?.Any() == true)
    {
        <ul>
            @foreach (var suggestion in Model.Suggestions)
            {
                <li>@suggestion</li>
            }
        </ul>
    }
    else
    {
        <p>No suggestions available.</p>
    }

    @if (status is not (MaintenanceStatus.Repaired or MaintenanceStatus.Closed))
    {
        <form asp-action="SubmitReport" asp-controller="DeviceReport" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="DeviceId" />
            <input type="hidden" asp-for="SerialNumber" />

            <div class="mb-3">
                <label asp-for="TechnicianReport" class="form-label">Issue Description</label>
                <textarea asp-for="TechnicianReport" class="form-control" rows="3"></textarea>
            </div>

            @if (status is not MaintenanceStatus.NeedsParts)
            {
                <div class="form-check form-switch">
                    <input asp-for="IsRepaired" class="form-check-input" id="CheckRepaired" />
                    <label class="form-check-label" for="CheckRepaired">Mark as Repaired</label>
                </div>
            }

            @if (status is not (MaintenanceStatus.NeedsParts or MaintenanceStatus.ApprovedByEngineer or MaintenanceStatus.ApprovedByOfficer))
            {
                <div class="form-check form-switch mt-2">
                    <input asp-for="RequestSpareParts" class="form-check-input" id="toggleSpareParts" />
                    <label class="form-check-label" for="toggleSpareParts">Request Spare Parts</label>
                </div>
            }

            <div id="RepairReportsection" class="mt-3" style="display:none;">
                <div class="mb-3">
                    <label for="ErrorKeyword" class="form-label">Error Keyword</label>
                    <input type="text" name="ErrorKeyword" class="form-control" />
                </div>
                <div class="mb-3">
                    <label for="SuggestedFix" class="form-label">How Was It Fixed?</label>
                    <textarea name="SuggestedFix" class="form-control" rows="3"></textarea>
                </div>
            </div>

            <div id="sparePartsSection" class="mt-4">
                <h5>Requested Spare Parts</h5>

                @if (Model.SparePartRequest.Items?.Any() == true)
                {
                    <table class="table" id="partsTable">
                        <thead class="table-dark">
                            <tr>
                                <th>Part</th>
                                <th>Warehouse</th>
                                <th>Quantity</th>
                                @if (status is not (MaintenanceStatus.NeedsParts or MaintenanceStatus.ApprovedByEngineer or MaintenanceStatus.ApprovedByOfficer))
                                {
                                    <th>Action</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < Model.SparePartRequest.Items.Count; i++)
                            {
                                var item = Model.SparePartRequest.Items[i];
                                <tr>
                                    <td>
                                        @if (status is not (MaintenanceStatus.NeedsParts or MaintenanceStatus.ApprovedByEngineer or MaintenanceStatus.ApprovedByOfficer))
                                        {
                                            <select name="SparePartRequest.Items[@i].ProductId" class="form-select">
                                                @foreach (var product in Model.Products)
                                                {
                                                    <option value="@product.Value" selected="@(product.Value == item.ProductId.ToString())">@product.Text</option>
                                                }
                                            </select>
                                        }
                                        else
                                        {
                                            @Model.Products.FirstOrDefault(p => p.Value == item.ProductId.ToString())?.Text
                                        }
                                    </td>
                                    <td>
                                        @if (status is not (MaintenanceStatus.NeedsParts or MaintenanceStatus.ApprovedByEngineer or MaintenanceStatus.ApprovedByOfficer))
                                        {
                                            <select name="SparePartRequest.Items[@i].StoreId" class="form-select">
                                                @foreach (var store in item.AvailableStores ?? new List<SelectListItem>())
                                                {
                                                    <option value="@store.Value" selected="@(store.Value == item.StoreId?.ToString())">@store.Text</option>
                                                }
                                            </select>
                                        }
                                        else
                                        {
                                            @item.AvailableStores?.FirstOrDefault(s => s.Value == item.StoreId?.ToString())?.Text
                                        }
                                    </td>
                                    <td>
                                        @if (status is not (MaintenanceStatus.NeedsParts or MaintenanceStatus.ApprovedByEngineer or MaintenanceStatus.ApprovedByOfficer))
                                        {
                                            <input type="number" name="SparePartRequest.Items[@i].Quantity" class="form-control" value="@item.Quantity" min="1" />
                                        }
                                        else
                                        {
                                            @item.Quantity
                                        }
                                    </td>
                                    @if (status is not (MaintenanceStatus.NeedsParts or MaintenanceStatus.ApprovedByEngineer or MaintenanceStatus.ApprovedByOfficer))
                                    {
                                        <td>
                                            <button type="button" class="btn btn-danger btn-sm" onclick="submitDelete(@item.Id, @Model.DeviceId)">
                                                <i class="bi bi-trash3"></i>
                                            </button>
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else if (!Model.RequestSpareParts)
                {
                    <div class="alert alert-info">No spare parts requested.</div>
                }

                <button type="button" class="btn btn-outline-secondary" id="sparePartsAdd" style="display:@(Model.RequestSpareParts ? "block" : "none")" onclick="addRow()">
                    <i class="bi bi-plus-circle"></i> Add Part
                </button>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-success">
                    <i class="bi bi-save"></i> Save Report
                </button>
            </div>
        </form>
    }
    else
    {
        <div class="mt-4">
            <h5>Parts Requested</h5>
            <table class="table">
                <thead class="table-dark">
                    <tr>
                        <th>Part</th>
                        <th>Warehouse</th>
                        <th>Quantity</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.SparePartRequest.Items)
                    {
                        <tr>
                            <td>@Model.Products.FirstOrDefault(p => p.Value == item.ProductId.ToString())?.Text</td>
                            <td>@item.AvailableStores?.FirstOrDefault(s => s.Value == item.StoreId?.ToString())?.Text</td>
                            <td>@item.Quantity</td>
                        </tr>
                    }
                </tbody>
            </table>
            <p class="text-danger text-center">Editing this report is not allowed.</p>
        </div>
    }

    <form id="deleteForm" asp-controller="SpareParts" asp-action="DeleteItemPart" method="post" class="d-none">
        @Html.AntiForgeryToken()
        <input type="hidden" name="DeviceId" id="deleteDeviceId" />
        <input type="hidden" name="Id" id="deleteItemId" />
    </form>
</div>

@section Scripts {
    <script>
        function submitDelete(id, deviceId) {
            document.getElementById("deleteItemId").value = id;
            document.getElementById("deleteDeviceId").value = deviceId;
            document.getElementById("deleteForm").submit();
        }

        document.addEventListener("DOMContentLoaded", function () {
            const toggle = document.getElementById("toggleSpareParts");
            const section = document.getElementById("sparePartsSection");
            const addButton = document.getElementById("sparePartsAdd");

            function toggleSpareParts(state) {
                section.style.display = state ? "block" : "none";
                addButton.style.display = state ? "block" : "none";
                section.querySelectorAll("input, select").forEach(el => el.disabled = !state);
            }

            if (toggle) {
                toggleSpareParts(toggle.checked);
                toggle.addEventListener("change", () => toggleSpareParts(toggle.checked));
            }

            const repairedToggle = document.getElementById("CheckRepaired");
            const repairSection = document.getElementById("RepairReportsection");

            function toggleRepairSection(state) {
                repairSection.style.display = state ? "block" : "none";
                repairSection.querySelectorAll("input, textarea").forEach(el => el.disabled = !state);
            }

            if (repairedToggle) {
                toggleRepairSection(repairedToggle.checked);
                repairedToggle.addEventListener("change", () => toggleRepairSection(repairedToggle.checked));
            }
        });

        let partIndex = @Model.SparePartRequest.Items?.Count() ?? 0;

        function addRow() {
            const row = `
                <tr>
                    <td>
                        <select name="SparePartRequest.Items[${partIndex}].ProductId" class="form-select">
                            @foreach (var product in Model.Products)
                            {
                                    <text><option value="@product.Value">@product.Text</option></text>
                            }
                        </select>
                    </td>
                    <td>
                        <select name="SparePartRequest.Items[${partIndex}].StoreId" class="form-select">
                            @foreach (var store in Model.SparePartRequest.Items.FirstOrDefault()?.AvailableStores ?? new List<SelectListItem>())
                            {
                                    <text><option value="@store.Value">@store.Text</option></text>
                            }
                        </select>
                    </td>
                    <td>
                        <input type="number" name="SparePartRequest.Items[${partIndex}].Quantity" class="form-control" value="1" min="1" />
                    </td>
                    <td>
                        <button type="button" class="btn btn-danger btn-sm" onclick="this.closest('tr').remove()">🗑️</button>
                    </td>
                </tr>`;
            document.querySelector("#partsTable tbody").insertAdjacentHTML("beforeend", row);
            partIndex++;
        }
    </script>
}
