@model List<Device>
@using WorkShop.Enums

@{
    ViewData["Title"] = "My Devices";

    string GetStatusColor(MaintenanceStatus s) => s switch
    {
        MaintenanceStatus.Pending => "secondary",
        MaintenanceStatus.AwaitingEngineer => "warning",
        MaintenanceStatus.ApprovedByEngineer => "primary",
        MaintenanceStatus.AwaitingOfficer => "info",
        MaintenanceStatus.ApprovedByOfficer => "success",
        MaintenanceStatus.RejectedByEngineer => "danger",
        MaintenanceStatus.RejectedByOfficer => "danger",
        MaintenanceStatus.Repaired => "success",
        MaintenanceStatus.Closed => "dark",
        _ => "secondary"
    };
}

<div class="container py-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0"><i class="bi bi-hdd-stack-fill me-2"></i>Devices Transferred to You</h4>
        </div>
        <div class="card-body">
            @if (!Model.Any())
            {
                <div class="alert alert-info">
                    <i class="bi bi-info-circle-fill me-2"></i> No devices transferred to you yet.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-bordered table-hover align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>Device Name</th>
                                <th>Serial Number</th>
                                <th>Department</th>
                                <th>Fault</th>
                                <th>Fault Date</th>
                                <th>Status</th>
                                
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var device in Model)
                            {
                                var status = (MaintenanceStatus)Enum.Parse(typeof(MaintenanceStatus), device.Status ?? "New");
                                <tr>
                                    <td class="text-truncate">@device.Product?.Name</td>
                                    <td>@device.SerialNumber</td>
                                    <td>@device.Department?.Name</td>
                                    <td>@device.ErrorKeyword</td>
                                    <td>@device.FaultDate.ToShortDateString()</td>
                                    <td>
                                        <span class="badge bg-@GetStatusColor(status) px-3 py-2">
                                            @status.ToString()
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <a asp-action="DeviceDetails" asp-route-id="@device.Id" class="btn btn-outline-primary btn-sm">
                                            <i class="bi bi-eye"></i> Details
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
