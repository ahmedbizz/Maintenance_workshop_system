@model WorkShop.ViewModel.DevicesViewModel
@using WorkShop.Enums
@using System.Text.Json
@{


    string GetStatusColor(MaintenanceStatus s) => s switch
    {
        MaintenanceStatus.Pending => "secondary",
        MaintenanceStatus.AwaitingEngineer => "warning",
        MaintenanceStatus.ApprovedByEngineer => "primary",
        MaintenanceStatus.AwaitingOfficer => "info",
        MaintenanceStatus.ApprovedByOfficer => "success",
        MaintenanceStatus.RejectedByEngineer => "danger",
        MaintenanceStatus.RejectedByOfficer => "danger",
        MaintenanceStatus.Repaired => "success",
        MaintenanceStatus.Closed => "dark",
        _ => "secondary"
    };
}






<div class="container my-4">

          
                <div class="card-header  text-primary text-center ">
        <h3 class="mb-0"><i class="bi bi-tools"></i> Maintenance devices</h3>
                </div>
                <div class="card-body">
                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-3 gap-2">
                        <h3 class="text-primary fw-bold fs-5 text-uppercase mb-0">Devices</h3>

                        <form class="d-flex gap-2" method="get">
                            <input class="form-control" type="search" name="searchTerm" placeholder="Search" value="@Model.searchTerm" />
                            <button class="btn btn-secondary" type="submit">Search</button>
                        </form>

                        @if (User.IsInRole("Engineer"))
                        {
                            <div class="d-flex gap-2">
                                <button type="button" class="btn btn-outline-secondary btnImportExcel" data-bs-toggle="modal" data-bs-target="#ImportExcel">
                                    <i class="bi bi-file-earmark-arrow-up"></i> Import Excel
                                </button>
                                <a asp-action="AddDevice" asp-controller="Device" class="btn btn-primary">
                                    <i class="bi bi-plus-lg"></i> Create
                                </a>
                            </div>
                        }
                    </div>


                    <div class="table-responsive">
                        <table class="table shadow table-hover align-middle text-center">
                            <thead class="table-dark">
                                <tr>
                                    <th>#</th>
                                    <th>Device</th>
                                    <th>S/N</th>
                                    <th>Department</th>
                                    <th>Technician</th>
                                    <th>Status</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var device in Model.devices)
                                {
                                    var status = (MaintenanceStatus)Enum.Parse(typeof(MaintenanceStatus), device.Status ?? "New");
                                    <tr>
                                        <td><img src="~/images/@device.Product?.imagePath" style="width:50px;height:50px" class="shadow rounded-circle" /></td>
                                        <td>@device.Product?.Name</td>
                                        <td>@device.SerialNumber</td>
                                        <td>@device.Department?.Name</td>
                                        <td>@device.Technician?.FullName</td>
                                        <td>
                                            <span class="badge bg-@GetStatusColor(status) px-3 py-2 rounded-pill">
                                                @status.ToString()
                                            </span>
                                        </td>
                                        <td >
                                            <a asp-action="DeviceDetails" class="btn btn-sm btn-warning" asp-controller="Device" asp-route-Id="@device.Id">
                                    <i class="bi bi-gear"></i>   Maintenance
                                            </a>
                                            @if (User.IsInRole("Engineer") && device.Status == MaintenanceStatus.New.ToString())
                                            {
                                                <button class="btn btn-sm btn-outline-primary"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#assignModal"
                                                        data-device-id="@device.Id">
                                                    Assign
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    @{
                        int maxPagesToShow = 5;
                        int startPage = Math.Max(1, Model.CurrentPage - maxPagesToShow / 2);
                        int endPage = Math.Min(Model.TotalPages, startPage + maxPagesToShow - 1);

                        // تعديل البداية إذا اقتربنا من النهاية
                        if (endPage - startPage < maxPagesToShow - 1)
                        {
                            startPage = Math.Max(1, endPage - maxPagesToShow + 1);
                        }
                    }

                    <nav>
                        <ul class="pagination justify-content-center">

                            <!-- زر السابق -->
                            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                                <a class="page-link" href="@Url.Action("Index", new { page = Model.CurrentPage - 1 })" aria-label="Previous">
                                    <span aria-hidden="true">&laquo;</span>
                                </a>
                            </li>

                            @for (int i = startPage; i <= endPage; i++)
                            {
                                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                    <a class="page-link" href="@Url.Action("Index", new { page = i })">@i</a>
                                </li>
                            }

                            <!-- زر التالي -->
                            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                                <a class="page-link" href="@Url.Action("Index", new { page = Model.CurrentPage + 1 })" aria-label="Next">
                                    <span aria-hidden="true">&raquo;</span>
                                </a>
                            </li>
                        </ul>
                    </nav>
                </div>
          

</div>

@* //Import From Excel *@
<div class="modal fade" id="ImportExcel">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="ImportExcel" asp-controller="Report" method="post" enctype="multipart/form-data">
                <div class="modal-header">
                    <h5 class="modal-title">Import Excel !!</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label>Table Name:</label>
                        <input name="TableName" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label>Excel file:</label>
                        <input type="file" name="file" accept=".xls,.xlsx" class="form-control" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-danger">Import</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </form>
        </div>
    </div>
</div>



<!-- Modal لعرض الخطأ -->
<div class="modal fade" id="errorModal" tabindex="-1" role="dialog" aria-labelledby="errorModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content border-danger">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="errorModalLabel">Deletion error</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p id="errorModalMessage">@TempData["DeleteError"]</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="messageModal" tabindex="-1" aria-labelledby="messageModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title" id="messageModalLabel">Message</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center">
                <p id="modalMessage"></p>
            </div>
        </div>
    </div>
</div>


<!-- Modal لتحويل الجهاز إلى فني -->
<div class="modal fade" id="assignModal" tabindex="-1" aria-labelledby="assignModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form method="post" asp-action="assignDevice" asp-controller="Device">
                <div class="modal-header">
                    <h5 class="modal-title">تحويل الجهاز إلى فني</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="DeviceId" id="modalDeviceId" />
                    <div class="mb-3">
                        <label for="technicianSelect" class="form-label">اختر الفني:</label>
                        <select class="form-select" name="technicionId" id="technicianSelect" required>
                            <option value="">-- اختر الفني --</option>
                            @foreach (var tech in Model.Technicians)
                            {
                                <option value="@tech.Value">@tech.Text</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-success">تحويل</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                </div>
            </form>
        </div>
    </div>
</div>




@section Scripts {
    <script>


        $('.btnImportExcel').click(function (e) {
          $('#ImportExcel').modal('show');
        });
            $(document).ready(function () {
            var errorMessage = '@TempData["DeleteError"]';
            if (errorMessage && errorMessage.trim() !== "") {
                var errorModal = new bootstrap.Modal(document.getElementById('errorModal'));
                errorModal.show();
            }
        });

                $(document).ready(function () {
            var success = @Html.Raw(JsonSerializer.Serialize(TempData["Success"]));
            var error = @Html.Raw(JsonSerializer.Serialize(TempData["Error"]));

            let message = success || error;
            if (message && message.trim() !== "") {
                $('#modalMessage').text(message);
                var modal = new bootstrap.Modal(document.getElementById('messageModal'));
                modal.show();
            }
        });


        $('#assignModal').on('show.bs.modal', function (event) {
            var button = $(event.relatedTarget);
            var deviceId = button.data('device-id');
            $('#modalDeviceId').val(deviceId);
        });

    </script>
    <style>
        body {
            background-color: #f8f9fa;
        }

        .table td, .table th {
            vertical-align: middle;
        }
    </style>

}


