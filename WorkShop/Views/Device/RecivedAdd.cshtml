@model WorkShop.ViewModel.DeviceInputViewModel

@{
    ViewData["Title"] = "Register a device for maintenance";
}
@using System.Text.Json
<div class="container mt-4">
    <h2 class="text-center text-primary mb-4"><i class="bi bi-wrench"></i> @ViewData["Title"]</h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form asp-action="RecivedAdd" asp-controller="Device" method="post" class="card shadow p-4 rounded-3">
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="SerialNumber" class="form-label fw-semibold"></label>
                <input asp-for="SerialNumber" class="form-control" />
                <span asp-validation-for="SerialNumber" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="FromLocation" class="form-label fw-semibold"></label>
                <input asp-for="FromLocation" class="form-control" />
                <span asp-validation-for="FromLocation" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="FaultDate" class="form-label fw-semibold"></label>
                <input asp-for="FaultDate" type="date" class="form-control" />
                <span asp-validation-for="FaultDate" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="ProductId" class="form-label fw-semibold"></label>
                <select asp-for="ProductId" asp-items="Model.Products" class="form-select">
                    <option value="">--  Select Device --</option>
                </select>
                <span asp-validation-for="ProductId" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="ComingFromDepartmentId" class="form-label fw-semibold"></label>
                <select asp-for="ComingFromDepartmentId" asp-items="Model.ComingFromDepartments" class="form-select">
                    <option value="">--    Select Department --</option>
                </select>
                <span asp-validation-for="ComingFromDepartmentId" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="DepartmentId" class="form-label fw-semibold"></label>
                <select asp-for="DepartmentId" asp-items="Model.Departments" class="form-select">
                    <option value="">--Select Department --</option>
                </select>
                <span asp-validation-for="DepartmentId" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="EngineerId" class="form-label fw-semibold"></label>
                <select asp-for="EngineerId" asp-items="Model.Engineers" class="form-select">
                    <option value="">--  Engineer --</option>
                </select>
                <span asp-validation-for="EngineerId" class="text-danger small"></span>
            </div>

            <div class="col-md-12">
                <label asp-for="FaultDescription" class="form-label fw-semibold"></label>
                <textarea asp-for="FaultDescription" class="form-control" rows="4"></textarea>
                <span asp-validation-for="FaultDescription" class="text-danger small"></span>
            </div>
        </div>

        <div class="mt-4 d-flex justify-content-end gap-2">
            <button type="submit" class="btn btn-success px-4">
                <i class="bi bi-save me-1"></i>  Create
            </button>
        </div>

        <div asp-validation-summary="All" class="text-danger mt-3 small"></div>
    </form>
</div>

<!-- Modal for Success/Error Message -->
<div class="modal fade" id="messageModal" tabindex="-1" aria-labelledby="messageModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-3">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title" id="messageModalLabel">Message</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center">
                <p id="modalMessage" class="mb-0"></p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const success = @Html.Raw(JsonSerializer.Serialize(TempData["Success"]));
            const error = @Html.Raw(JsonSerializer.Serialize(TempData["Error"]));
            const message = success || error;

            if (message && message.trim() !== "") {
                document.getElementById("modalMessage").textContent = message;
                const modal = new bootstrap.Modal(document.getElementById("messageModal"));
                modal.show();
            }
        });
    </script>
}
